---
import type { ArtVolume } from "../data/artworks";
import { getArtworksForVolume } from "../data/artworks";

type Props = {
  volume: ArtVolume;
  index: number;
};

const { volume, index } = Astro.props;
const drawings = getArtworksForVolume(volume.slug);
const [first, second, third] = volume.coverPalette;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<article
  class:list={[
    "art-volume-card group overflow-hidden rounded-lg border border-[var(--color-line)] bg-[var(--color-card)] shadow-sm transition hover:-translate-y-1 hover:shadow-xl",
    index === 0 ? "xl:col-span-2" : "",
  ]}
>
  <details class="h-full" open={index === 0}>
    <summary class="cursor-pointer list-none marker:hidden">
      <div
        class="relative min-h-64 overflow-hidden"
        style={`background: linear-gradient(135deg, ${first}, ${second} 58%, ${third});`}
      >
        <div class="absolute inset-0 opacity-25 mix-blend-screen art-tile-pattern"></div>
        <div class="absolute left-5 top-5 rounded-md bg-white/75 px-3 py-2 text-xs font-black uppercase tracking-[0.16em] backdrop-blur">
          {volume.year}
        </div>
        <div class="absolute right-5 top-5 rounded-full border border-white/50 bg-white/75 px-3 py-1.5 text-xs font-black uppercase tracking-[0.12em] backdrop-blur transition group-open:bg-[var(--color-ink)] group-open:text-white">
          <span class="group-open:hidden">Expand</span>
          <span class="hidden group-open:inline">Open</span>
        </div>
        <div class="absolute bottom-5 left-5 right-5 grid grid-cols-3 gap-2">
          {
            drawings.slice(0, 3).map((drawing) => (
              <div
                class="aspect-[3/4] rounded-md border border-white/40 shadow-sm transition group-hover:-translate-y-1"
                style={`background: linear-gradient(135deg, ${drawing.palette[0]}, ${drawing.palette[1]} 58%, ${drawing.palette[2]});`}
              >
              </div>
            ))
          }
        </div>
      </div>

      <div class="space-y-3 p-4">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-[var(--color-accent)]">
          {drawings.length} drawings
        </p>
        <h2 class="text-2xl font-black">{volume.title}</h2>
        <p class="leading-7 text-[var(--color-muted)]">{volume.subtitle}</p>
      </div>
    </summary>

    <div class="border-t border-[var(--color-line)] p-4 pt-3">
      <p class="leading-7 text-[var(--color-muted)]">{volume.note}</p>

      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <div class="rounded-md border border-[var(--color-line)] bg-[rgba(30,27,46,0.035)] p-3">
          <p class="text-xs font-black uppercase tracking-[0.16em] text-[var(--color-muted)]">
            Drawings inside
          </p>
          <div class="mt-3 flex flex-wrap gap-2">
            {
              drawings.map((drawing) => (
                <span class="rounded border border-[var(--color-line)] bg-white/70 px-2.5 py-1 text-xs font-bold text-[var(--color-muted)]">
                  {drawing.title}
                </span>
              ))
            }
          </div>
        </div>

        <div class="rounded-md border border-[var(--color-line)] bg-[rgba(45,156,140,0.08)] p-3">
          <p class="text-xs font-black uppercase tracking-[0.16em] text-[var(--color-muted)]">
            Future features
          </p>
          <div class="mt-3 flex flex-wrap gap-2">
            {
              volume.featureIdeas.map((feature) => (
                <span class="rounded border border-[rgba(45,156,140,0.28)] bg-white/70 px-2.5 py-1 text-xs font-bold text-[var(--color-muted)]">
                  {feature}
                </span>
              ))
            }
          </div>
        </div>
      </div>

      <a
        class="mt-4 inline-flex rounded-md bg-[var(--color-ink)] px-3 py-2 text-sm font-black text-white transition hover:-translate-y-0.5"
        href={`${base}art/collections/${volume.slug}/`}
      >
        Open drawing pack
      </a>
    </div>
  </details>
</article>

---
type Props = {
  title: string;
  embedUrl?: string;
  videoUrl?: string;
  autoplay?: boolean;
  load?: "eager" | "poster";
};

const {
  title,
  embedUrl,
  videoUrl,
  autoplay = false,
  load = "poster",
} = Astro.props;

const getEmbedUrl = (url: string) => {
  try {
    const parsed = new URL(url);
    if (autoplay) {
      parsed.searchParams.set("autoplay", "1");
      parsed.searchParams.set("mute", "1");
      parsed.searchParams.set("playsinline", "1");
    }
    parsed.searchParams.set("controls", "0");
    parsed.searchParams.set("iv_load_policy", "3");
    parsed.searchParams.set("modestbranding", "1");
    parsed.searchParams.set("rel", "0");
    parsed.searchParams.set("disablekb", "1");

    const embedId = parsed.pathname.split("/").filter(Boolean).pop();
    if (embedId && parsed.hostname.includes("youtube")) {
      parsed.searchParams.set("loop", "1");
      parsed.searchParams.set("playlist", embedId);
    }

    return parsed.toString();
  } catch {
    const separator = url.includes("?") ? "&" : "?";
    return `${url}${separator}controls=0&iv_load_policy=3&modestbranding=1&rel=0`;
  }
};

const getYouTubeId = (url: string | undefined) => {
  if (!url) return "";
  try {
    const parsed = new URL(url);
    if (!parsed.hostname.includes("youtube")) return "";
    return parsed.pathname.split("/").filter(Boolean).pop() ?? "";
  } catch {
    return "";
  }
};

const finalEmbedUrl = embedUrl ? getEmbedUrl(embedUrl) : "";
const youtubeId = getYouTubeId(finalEmbedUrl);
const posterUrl = youtubeId
  ? `https://i.ytimg.com/vi/${youtubeId}/hqdefault.jpg`
  : "";
const shouldLoadIframe = Boolean(finalEmbedUrl && load === "eager");
---

<div
  class="video-embed media-frame"
  data-video-embed
>
  {
    finalEmbedUrl ? (
      shouldLoadIframe ? (
        <iframe
          class="aspect-video w-full"
          src={finalEmbedUrl}
          title={title}
          loading={autoplay ? "eager" : "lazy"}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        />
      ) : (
        <button
          class="video-embed__poster group relative grid aspect-video w-full place-items-center overflow-hidden text-left text-white"
          type="button"
          data-video-loader
          data-video-src={finalEmbedUrl}
          data-video-title={title}
          aria-label={`Load video: ${title}`}
        >
          {
            posterUrl && (
              <img
                class="absolute inset-0 h-full w-full object-cover opacity-70 transition group-hover:scale-105 group-hover:opacity-82"
                src={posterUrl}
                alt=""
                loading="lazy"
              />
            )
          }
          <span class="absolute inset-0 bg-[linear-gradient(180deg,rgba(36,32,44,0.18),rgba(36,32,44,0.72))]"></span>
          <span class="relative flex max-w-[85%] flex-col items-center gap-3 text-center">
            <span class="video-embed__play grid h-14 w-14 place-items-center rounded-full border border-white/40 bg-white/18 text-sm font-black shadow-sm transition group-hover:scale-105">
              Play
            </span>
            <span class="text-sm font-black leading-tight">{title}</span>
          </span>
        </button>
      )
    ) : (
      <div class="flex aspect-video w-full flex-col items-center justify-center gap-3 p-6 text-center text-white">
        <div class="grid h-14 w-14 place-items-center rounded-full border border-white/30 bg-white/10 text-lg font-black">
          Play
        </div>
        <div>
          <p class="font-bold">{title}</p>
          <p class="mt-1 text-sm text-white/68">
            Add a YouTube or Vimeo embed URL to make this card playable.
          </p>
        </div>
        {
          videoUrl && (
            <a class="text-sm font-semibold underline underline-offset-4" href={videoUrl}>
              Open video
            </a>
          )
        }
      </div>
    )
  }
</div>

<script>
  const loadVideoPosters = () => {
    document.querySelectorAll("[data-video-loader]").forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;

      button.addEventListener(
        "click",
        () => {
          const src = button.dataset.videoSrc;
          const title = button.dataset.videoTitle ?? "Video";
          if (!src) return;

          const iframe = document.createElement("iframe");
          iframe.className = "aspect-video w-full";
          iframe.src = src;
          iframe.title = title;
          iframe.loading = "lazy";
          iframe.allow =
            "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
          iframe.allowFullscreen = true;
          button.replaceWith(iframe);
        },
        { once: true },
      );
    });
  };

  document.addEventListener("astro:page-load", loadVideoPosters);
  loadVideoPosters();
</script>

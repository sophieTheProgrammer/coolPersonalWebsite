---
import DoodleImage from "../components/DoodleImage.astro";
import { artworks, getArtAssetPath, isPdfArtwork } from "../data/artworks";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Art | Cool Personal Website"
  description="A simple art gallery for scans, drawings, and sketchbook pages."
>
  <main class="art-page-shell min-h-screen overflow-hidden px-6 py-12 sm:px-10">
    <div class="art-garden-field" aria-hidden="true">
      <span class="art-garden-blob art-garden-blob--one"></span>
      <span class="art-garden-blob art-garden-blob--two"></span>
      <span class="art-garden-blob art-garden-blob--three"></span>
      <span class="art-garden-blob art-garden-blob--four"></span>
      <div class="art-garden-doodle art-garden-doodle--one">
        <DoodleImage src="garden-blob-01.png" alt="Hand-drawn garden blob" variant="cover" animation="float" hideWhenMissing />
      </div>
      <div class="art-garden-doodle art-garden-doodle--two">
        <DoodleImage src="garden-blob-02.png" alt="Hand-drawn garden flower blob" variant="cover" animation="float" hideWhenMissing />
      </div>
    </div>

    <section class="relative z-10 mx-auto max-w-6xl">
      <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-muted)]">
            Art Garden
          </p>
          <h1 class="mt-4 text-4xl font-black leading-none sm:text-6xl">
            See my drawings here!
          </h1>
        </div>
        <p class="max-w-2xl text-lg leading-8 text-[var(--color-muted)]">
          A simple wall for scans, sketches, finished pieces, and PDFs I want to
          keep visible without making every drawing a whole project page.
        </p>
      </div>

      <div class="art-simple-gallery mt-10">
        {
          artworks.map((artwork, index) => {
            const src = getArtAssetPath(artwork.src);
            const isPdf = isPdfArtwork(artwork.src);

            return (
              <figure class="art-simple-card" style={`--art-tilt: ${(index % 5 - 2) * 0.45}deg;`}>
                <div class="art-simple-card__media">
                  {
                    isPdf ? (
                      <object data={src} type="application/pdf" aria-label={artwork.alt ?? artwork.title ?? "Artwork PDF"}>
                        <a href={src}>Open PDF</a>
                      </object>
                    ) : (
                      <img
                        src={src}
                        alt={artwork.alt ?? artwork.title ?? "Artwork"}
                        loading="lazy"
                        onerror="this.closest('.art-simple-card')?.classList.add('art-simple-card--missing')"
                      />
                    )
                  }
                  <div class="art-simple-card__placeholder">
                    <span>{artwork.title ?? "Art scan"}</span>
                  </div>
                </div>
                {
                  (artwork.title || artwork.note) && (
                    <figcaption>
                      {artwork.title && <strong>{artwork.title}</strong>}
                      {artwork.note && <span>{artwork.note}</span>}
                    </figcaption>
                  )
                }
              </figure>
            );
          })
        }
      </div>
    </section>
  </main>
</BaseLayout>

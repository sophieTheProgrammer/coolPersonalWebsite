---
import DoodleImage from "./DoodleImage.astro";
import VideoEmbed from "./VideoEmbed.astro";
import type { ComboLog, SkillToy } from "../data/skillToys";

type Props = {
  combo: ComboLog;
  toy: SkillToy;
};

const { combo, toy } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<article class="active-clip-card min-w-0 overflow-hidden rounded-lg border border-[var(--color-line)] bg-[var(--color-card)] shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
  <div class="active-clip-card__video">
    <VideoEmbed title={combo.title} embedUrl={combo.embedUrl} autoplay />
  </div>
  <div class="space-y-3 p-4">
    <div class="flex items-start justify-between gap-3">
      <div>
        <div class="flex items-center gap-2">
          <DoodleImage src={toy.doodleIcon} alt={`${toy.name} hand-drawn icon`} label={toy.name.slice(0, 2)} variant="icon" animation="bob" />
          <p class="text-xs font-black uppercase tracking-[0.18em] text-[var(--color-accent)]">
            {toy.name}
          </p>
        </div>
        <h3 class="mt-1 text-lg font-black leading-tight">{combo.title}</h3>
      </div>
      <div class="flex shrink-0 flex-col items-end gap-1">
        <span class="rounded border border-[var(--color-line)] px-2 py-1 text-xs font-bold text-[var(--color-muted)]">
          {combo.tag}
        </span>
      </div>
    </div>
    <p class="line-clamp-2 text-sm leading-6 text-[var(--color-muted)]">{combo.notes}</p>
    <a
      class="inline-flex rounded border border-[var(--color-line)] px-2.5 py-1.5 text-xs font-black uppercase tracking-[0.12em] text-[var(--color-muted)] transition hover:border-[var(--color-accent)] hover:text-[var(--color-ink)]"
      href={`${base}skill-toys/${toy.slug}/`}
    >
      All {toy.name} tricks
    </a>
  </div>
</article>

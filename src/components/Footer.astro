---
import { siteInfo } from "../data/site";
---

<footer class="mt-20 border-t border-[var(--color-line)] bg-[rgba(255,255,255,0.44)] px-6 py-10 sm:px-10">
  <div class="mx-auto flex max-w-6xl flex-wrap items-end justify-between gap-6">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.2em] text-[var(--color-muted)]">
        {siteInfo.status}
      </p>
      <h2 class="mt-3 text-2xl font-black">{siteInfo.name}</h2>
      <p class="mt-3 max-w-md leading-7 text-[var(--color-muted)]">{siteInfo.description}</p>
    </div>
    <p class="max-w-xs text-sm font-semibold leading-6 text-[var(--color-muted)]">
      Built as a small studio wall for clips, code, and art.
    </p>
  </div>
</footer>

---
import CodingProjectCard from "../components/CodingProjectCard.astro";
import TerminalPanel from "../components/TerminalPanel.astro";
import { codingProjects } from "../data/codingProjects";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Coding | Cool Personal Website"
  description="Coding projects, current builds, and GAME JAMS!!."
>
  <main class="min-h-screen px-6 py-12 sm:px-10">
    <section class="mx-auto max-w-6xl">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(26rem,1.05fr)] lg:items-start">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-muted)]">
            Coding workbench
          </p>
          <h1 class="mt-4 max-w-4xl text-4xl font-black leading-none sm:text-6xl">
            Projects
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--color-muted)]">
            Page for all my computer science related stuff.
          </p>
        </div>
        <TerminalPanel />
      </div>

      <section class="mt-12" aria-labelledby="projects-heading">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.22em] text-[var(--color-muted)]">
              Project stack
            </p>
            <h2 id="projects-heading" class="mt-2 text-3xl font-black">
              Build log
            </h2>
          </div>
          <p class="text-sm font-semibold text-[var(--color-muted)]">
            {codingProjects.length} entries
          </p>
        </div>

        <div class="mt-5 grid gap-4">
          {codingProjects.map((project) => <CodingProjectCard project={project} />)}
        </div>
      </section>

    </section>
  </main>
</BaseLayout>

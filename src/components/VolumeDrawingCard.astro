---
import type { Artwork } from "../data/artworks";

type Props = {
  artwork: Artwork;
  index: number;
};

const { artwork, index } = Astro.props;
const [first, second, third] = artwork.palette;
const hasImage = Boolean(artwork.imageSrc);
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const mediaSrc = artwork.imageSrc?.startsWith("/")
  ? `${base}${artwork.imageSrc.slice(1)}`
  : artwork.imageSrc;
const processSrc = artwork.processSrc?.startsWith("/")
  ? `${base}${artwork.processSrc.slice(1)}`
  : artwork.processSrc;
const isPdf = mediaSrc?.toLowerCase().endsWith(".pdf");
---

<article class="group overflow-hidden rounded-lg border border-[var(--color-line)] bg-[var(--color-card)] shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
  <div
    class="relative aspect-[3/4] overflow-hidden"
    style={hasImage ? undefined : `background: linear-gradient(135deg, ${first}, ${second} 58%, ${third});`}
  >
    {
      mediaSrc && isPdf ? (
        <iframe
          class="h-full w-full bg-white"
          src={mediaSrc}
          title={artwork.title}
          loading="lazy"
        />
      ) : mediaSrc ? (
        <>
          <img
            class:list={[
              "h-full w-full object-cover transition duration-300",
              processSrc ? "group-hover:opacity-0 group-focus-within:opacity-0" : "",
            ]}
            src={mediaSrc}
            alt={artwork.title}
            loading="lazy"
          />
          {
            processSrc && (
              <img
                class="absolute inset-0 h-full w-full object-cover opacity-0 transition duration-300 group-hover:opacity-100 group-focus-within:opacity-100"
                src={processSrc}
                alt={`${artwork.title} process sketch`}
                loading="lazy"
              />
            )
          }
        </>
      ) : (
        <>
      <div class="absolute inset-0 opacity-25 mix-blend-screen art-tile-pattern"></div>
      <div class="absolute right-3 top-3 rounded bg-white/70 px-2 py-1 text-xs font-black backdrop-blur">
        {String(index + 1).padStart(2, "0")}
      </div>
        </>
      )
    }
  </div>
  <div class="p-4">
    <p class="text-xs font-black uppercase tracking-[0.18em] text-[var(--color-accent)]">
      {artwork.medium}
    </p>
    <h2 class="mt-2 text-xl font-black">{artwork.title}</h2>
    <p class="mt-2 leading-7 text-[var(--color-muted)]">{artwork.note}</p>
  </div>
</article>

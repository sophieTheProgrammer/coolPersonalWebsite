---
import { artworks } from "../data/artworks";

const palettes = artworks.map((artwork) => ({
  title: artwork.title,
  mood: artwork.mood,
  colors: artwork.palette,
}));
---

<section
  class="palette-lab rounded-lg border border-[var(--color-line)] bg-[var(--color-card)] p-4 shadow-sm"
  data-palettes={JSON.stringify(palettes)}
>
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.2em] text-[var(--color-muted)]">
        palette lab
      </p>
      <h2 class="mt-2 text-2xl font-black" data-palette-title>{palettes[0].title}</h2>
    </div>
    <button
      class="rounded-md bg-[var(--color-ink)] px-3 py-2 text-sm font-black text-white transition hover:-translate-y-0.5"
      type="button"
      data-palette-button
    >
      Mix
    </button>
  </div>

  <div class="mt-5 grid grid-cols-3 overflow-hidden rounded-lg border border-[var(--color-line)]" data-palette-strip>
    {
      palettes[0].colors.map((color) => (
        <div class="h-20" style={`background: ${color}`}></div>
      ))
    }
  </div>
  <p class="mt-3 text-sm font-bold text-[var(--color-muted)]" data-palette-mood>
    mood: {palettes[0].mood}
  </p>
</section>

<script>
  document.querySelectorAll(".palette-lab").forEach((lab) => {
    const palettes = JSON.parse(lab.getAttribute("data-palettes") ?? "[]") as Array<{
      title: string;
      mood: string;
      colors: string[];
    }>;
    const title = lab.querySelector("[data-palette-title]");
    const mood = lab.querySelector("[data-palette-mood]");
    const strip = lab.querySelector("[data-palette-strip]");
    const button = lab.querySelector("[data-palette-button]");
    let index = 0;

    const render = () => {
      const palette = palettes[index % palettes.length];
      if (!palette) return;
      if (title) title.textContent = palette.title;
      if (mood) mood.textContent = `mood: ${palette.mood}`;
      if (strip) {
        strip.innerHTML = palette.colors
          .map((color) => `<div class="h-20" style="background: ${color}"></div>`)
          .join("");
      }
    };

    button?.addEventListener("click", () => {
      index += 1;
      render();
    });
  });
</script>

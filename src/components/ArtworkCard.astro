---
import type { Artwork } from "../data/artworks";

type Props = {
  artwork: Artwork;
  index: number;
};

const { artwork, index } = Astro.props;
const [first, second, third] = artwork.palette;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<article class="group overflow-hidden rounded-lg border border-[var(--color-line)] bg-[var(--color-card)] shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
  <a class="block" href={`${base}art/${artwork.slug}/`} aria-label={`Open ${artwork.title}`}>
    <div
      class="relative aspect-[4/3] overflow-hidden"
      style={`background: linear-gradient(135deg, ${first}, ${second} 54%, ${third});`}
    >
      <div class="absolute inset-0 opacity-30 mix-blend-screen art-tile-pattern"></div>
      <div
        class:list={[
          "absolute rounded-full border border-white/35 bg-white/20 backdrop-blur-sm transition duration-500 group-hover:scale-110",
          index % 3 === 0
            ? "left-8 top-8 h-24 w-24"
            : index % 3 === 1
              ? "bottom-8 right-8 h-28 w-28"
              : "left-1/2 top-1/2 h-32 w-32 -translate-x-1/2 -translate-y-1/2",
        ]}
      >
      </div>
      <div class="absolute bottom-3 left-3 rounded-md bg-black/28 px-3 py-2 text-sm font-black text-white backdrop-blur">
        {artwork.status}
      </div>
    </div>
  </a>
  <div class="space-y-4 p-4">
    <div>
      <h2 class="text-xl font-black">{artwork.title}</h2>
    </div>
    <p class="leading-7 text-[var(--color-muted)]">{artwork.note}</p>
    <div class="flex items-center justify-between gap-4">
      <span class="rounded border border-[var(--color-line)] px-2.5 py-1 text-xs font-bold text-[var(--color-muted)]">
        {artwork.mood}
      </span>
      <div class="flex gap-1.5" aria-label={`${artwork.title} color palette`}>
        {
          artwork.palette.map((color) => (
            <span
              class="h-5 w-5 rounded-full border border-black/10"
              style={`background: ${color}`}
            />
          ))
        }
      </div>
    </div>
  </div>
</article>

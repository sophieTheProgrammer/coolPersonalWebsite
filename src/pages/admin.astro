---
import BaseLayout from "../layouts/BaseLayout.astro";
import { artVolumes } from "../data/artworks";
import { skillToys } from "../data/skillToys";
---

<BaseLayout
  title="Admin Helper | Cool Personal Website"
  description="A local helper page for writing art uploads and generating skill toy data snippets."
>
  <main class="min-h-screen px-6 py-12 sm:px-10">
    <section class="mx-auto max-w-5xl">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-muted)]">
        Admin helper
      </p>
      <h1 class="mt-4 text-4xl font-black leading-none sm:text-6xl">
        Add stuff locally
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--color-muted)]">
        Start the local writer with <code>npm run admin:server</code>, then upload
        art files into <code>public/art/</code> and attach image uploads to packets.
      </p>

      <div class="mt-10 grid gap-5 lg:grid-cols-2">
        <form class="admin-card admin-panel site-card" data-art-upload-form>
          <div>
            <p class="text-xs font-black uppercase tracking-[0.18em] text-[var(--color-muted)]">
              Local writer
            </p>
            <h2 class="mt-2 text-3xl leading-none">Upload art</h2>
          </div>
          <label class="field-stack">
            <span>Image or PDF</span>
            <input class="form-field" name="file" type="file" accept="image/*,.pdf" required />
          </label>
          <label class="field-stack">
            <span>Packet</span>
            <select class="form-field" name="packetSlug">
              {artVolumes.map((volume) => <option value={volume.slug}>{volume.title}</option>)}
            </select>
          </label>
          <label class="field-stack">
            <span>Drawing title</span>
            <input class="form-field" name="title" placeholder="Sketchbook scan" required />
          </label>
          <label class="field-stack">
            <span>Note</span>
            <textarea class="form-field form-field--textarea" name="note" placeholder="Optional tiny note"></textarea>
          </label>
          <label class="field-stack">
            <span>Process/sketch image path</span>
            <input class="form-field" name="processSrc" placeholder="/art/sketch-upload.png" />
          </label>
          <div class="media-frame admin-upload-preview" data-upload-preview>
            <span>Select an image or PDF</span>
          </div>
          <div class="admin-pdf-pages" data-pdf-pages hidden></div>
          <div class="flex flex-wrap gap-2">
            <button class="site-button site-button--dark px-4 py-3" type="submit">
              Upload file
            </button>
            <button class="site-button px-4 py-3" type="button" data-save-artwork disabled>
              Save to packet
            </button>
          </div>
          <pre class="admin-output" data-art-output>Writer status will appear here.</pre>
        </form>

        <form class="admin-card admin-panel site-card" data-trick-form>
          <div>
            <p class="text-xs font-black uppercase tracking-[0.18em] text-[var(--color-muted)]">
              Trick entry
            </p>
            <h2 class="mt-2 text-3xl leading-none">YouTube clip</h2>
          </div>
          <label class="field-stack">
            <span>Toy</span>
            <select class="form-field" name="toySlug">
              {skillToys.map((toy) => <option value={toy.slug}>{toy.name}</option>)}
            </select>
          </label>
          <label class="field-stack">
            <span>YouTube URL or ID</span>
            <input class="form-field" name="youtube" placeholder="https://youtu.be/..." required />
          </label>
          <label class="field-stack">
            <span>Title</span>
            <input class="form-field" name="title" placeholder="Leave as YouTube title later" />
          </label>
          <label class="field-stack">
            <span>Notes</span>
            <textarea class="form-field form-field--textarea" name="notes" placeholder="Leave as YouTube description later"></textarea>
          </label>
          <button class="site-button site-button--dark" type="submit">Generate trick snippet</button>
          <pre class="admin-output" data-trick-output></pre>
        </form>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  import * as pdfjsLib from "pdfjs-dist";
  import pdfWorkerSrc from "pdfjs-dist/build/pdf.worker.mjs?url";

  pdfjsLib.GlobalWorkerOptions.workerSrc = pdfWorkerSrc;

  const writerUrl = "http://localhost:8787";

  const slugify = (value: string) =>
    value
      .toLowerCase()
      .trim()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-|-$/g, "");

  const getYouTubeId = (value: string) => {
    try {
      const parsed = new URL(value);
      if (parsed.hostname.includes("youtu.be")) {
        return parsed.pathname.split("/").filter(Boolean)[0] ?? value;
      }
      if (parsed.pathname.startsWith("/shorts/")) {
        return parsed.pathname.split("/").filter(Boolean)[1] ?? value;
      }
      return parsed.searchParams.get("v") ?? value;
    } catch {
      return value;
    }
  };

  const artForm = document.querySelector("[data-art-upload-form]");
  const artOutput = document.querySelector("[data-art-output]");
  const saveArtworkButton = document.querySelector("[data-save-artwork]");
  const preview = document.querySelector("[data-upload-preview]");
  const pdfPagesPreview = document.querySelector("[data-pdf-pages]");
  let uploadedFile: { src: string; kind: "image" | "pdf" } | null = null;
  let renderedPdfPages: { pageNumber: number; dataUrl: string }[] = [];

  const writeOutput = (message: string) => {
    if (artOutput instanceof HTMLElement) {
      artOutput.textContent = message;
    }
  };

  const renderPdfPages = async (file: File) => {
    if (!(pdfPagesPreview instanceof HTMLElement)) return;

    renderedPdfPages = [];
    pdfPagesPreview.hidden = false;
    pdfPagesPreview.textContent = "Rendering PDF pages...";

    const bytes = new Uint8Array(await file.arrayBuffer());
    const pdf = await pdfjsLib.getDocument({ data: bytes }).promise;
    const pages: { pageNumber: number; dataUrl: string }[] = [];

    pdfPagesPreview.innerHTML = "";

    for (let pageNumber = 1; pageNumber <= pdf.numPages; pageNumber += 1) {
      const page = await pdf.getPage(pageNumber);
      const viewport = page.getViewport({ scale: 1.45 });
      const canvas = document.createElement("canvas");
      const context = canvas.getContext("2d");
      if (!context) continue;

      canvas.width = Math.ceil(viewport.width);
      canvas.height = Math.ceil(viewport.height);
      await page.render({ canvas, canvasContext: context, viewport }).promise;

      const dataUrl = canvas.toDataURL("image/png");
      pages.push({ pageNumber, dataUrl });

      const label = document.createElement("label");
      label.className = "admin-pdf-page";
      label.innerHTML = `
        <input type="checkbox" value="${pageNumber}" checked />
        <img src="${dataUrl}" alt="PDF page ${pageNumber}" />
        <span>Page ${pageNumber}</span>
      `;
      pdfPagesPreview.append(label);
    }

    renderedPdfPages = pages;
    writeOutput(`Rendered ${pages.length} PDF page${pages.length === 1 ? "" : "s"} for packet import.`);
  };

  const renderPreview = async (file: File) => {
    if (!(preview instanceof HTMLElement)) return;
    const url = URL.createObjectURL(file);
    renderedPdfPages = [];

    if (pdfPagesPreview instanceof HTMLElement) {
      pdfPagesPreview.hidden = true;
      pdfPagesPreview.innerHTML = "";
    }

    if (file.type === "application/pdf") {
      preview.innerHTML = `<iframe title="PDF preview" src="${url}"></iframe>`;
      await renderPdfPages(file);
      return;
    }

    preview.innerHTML = `<img src="${url}" alt="Upload preview" />`;
  };

  artForm?.querySelector<HTMLInputElement>('input[type="file"]')?.addEventListener("change", async (event) => {
    const input = event.currentTarget;
    if (!(input instanceof HTMLInputElement)) return;
    const file = input.files?.[0];
    uploadedFile = null;

    if (saveArtworkButton instanceof HTMLButtonElement) {
      saveArtworkButton.disabled = true;
    }

    if (file) {
      await renderPreview(file);
      writeOutput(`Ready to upload: ${file.name}`);
    }
  });

  artForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    if (!(form instanceof HTMLFormElement)) return;

    const data = new FormData(form);
    writeOutput("Uploading to local writer...");

    try {
      const response = await fetch(`${writerUrl}/api/upload`, {
        method: "POST",
        body: data,
      });
      const result = await response.json();
      if (!result.ok) throw new Error(result.error);

      uploadedFile = result.file;
      if (saveArtworkButton instanceof HTMLButtonElement) {
        saveArtworkButton.disabled = false;
      }

      writeOutput(
        uploadedFile?.kind === "pdf"
          ? `Uploaded ${result.file.src}\nReady to save this PDF into the selected packet.`
          : `Uploaded ${result.file.src}\nReady to save this image into the selected packet.`,
      );
    } catch (error) {
      writeOutput(`Writer unavailable or failed.\nRun: npm run admin:server\n\n${error}`);
    }
  });

  saveArtworkButton?.addEventListener("click", async () => {
    if (!(artForm instanceof HTMLFormElement) || !uploadedFile) {
      return;
    }

    const data = new FormData(artForm);
    writeOutput("Writing drawing data...");

    try {
      if (uploadedFile.kind === "pdf") {
        const selectedPageNumbers = new Set(
          Array.from(document.querySelectorAll<HTMLInputElement>("[data-pdf-pages] input:checked"))
            .map((input) => Number(input.value)),
        );
        const pages = renderedPdfPages.filter((page) => selectedPageNumbers.has(page.pageNumber));

        const response = await fetch(`${writerUrl}/api/pdf-pages`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            packetSlug: data.get("packetSlug"),
            title: data.get("title"),
            note: data.get("note"),
            pages,
          }),
        });
        const result = await response.json();
        if (!result.ok) throw new Error(result.error);

        writeOutput(`Saved PDF pages: ${result.artwork.slugs.join(", ")}\nRefresh dev server to see them.`);
        return;
      }

      const response = await fetch(`${writerUrl}/api/artwork`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          packetSlug: data.get("packetSlug"),
          title: data.get("title"),
          note: data.get("note"),
          imageSrc: uploadedFile.src,
          processSrc: data.get("processSrc"),
          kind: uploadedFile.kind,
        }),
      });
      const result = await response.json();
      if (!result.ok) throw new Error(result.error);

      writeOutput(`Saved drawing: ${result.artwork.slug}\nRun npm run build or refresh dev server to see it.`);
    } catch (error) {
      writeOutput(`Could not save drawing.\n${error}`);
    }
  });

  document.querySelector("[data-trick-form]")?.addEventListener("submit", (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    if (!(form instanceof HTMLFormElement)) return;

    const data = new FormData(form);
    const toySlug = String(data.get("toySlug") ?? "");
    const youtubeId = getYouTubeId(String(data.get("youtube") ?? "").trim());
    const title = String(data.get("title") ?? "").trim() || "YouTube title";
    const notes = String(data.get("notes") ?? "").trim() || "YouTube description";
    const today = new Date().toISOString().slice(0, 10);
    const output = form.querySelector("[data-trick-output]");
    if (!youtubeId || !(output instanceof HTMLElement)) return;

    output.textContent = `{
  id: ${JSON.stringify(`${toySlug}-${slugify(title)}-${today}`)},
  toySlug: ${JSON.stringify(toySlug)},
  title: ${JSON.stringify(title)},
  date: ${JSON.stringify(today)},
  tag: "practice",
  youtubeId: ${JSON.stringify(youtubeId)},
  notes: ${JSON.stringify(notes)},
},`;
  });
</script>

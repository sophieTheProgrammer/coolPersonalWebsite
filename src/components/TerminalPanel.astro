---
import DoodleImage from "./DoodleImage.astro";
import { terminalCommands } from "../data/codingProjects";
import { codingDoodles } from "../data/site";
---

<section class="tiny-terminal rounded-lg border border-[var(--color-line)] bg-[var(--color-ink)] p-4 text-white shadow-sm">
  <div class="flex items-start justify-between gap-3 border-b border-white/10 pb-3">
    <div class="flex items-center gap-2">
      <span class="h-3 w-3 rounded-full bg-[#e4577a]"></span>
      <span class="h-3 w-3 rounded-full bg-[#f4d35e]"></span>
      <span class="h-3 w-3 rounded-full bg-[#2d9c8c]"></span>
      <p class="ml-2 text-xs font-bold uppercase tracking-[0.2em] text-white/55">
        tiny terminal
      </p>
    </div>
    <DoodleImage src={codingDoodles.terminalAccent} alt="Hand-drawn terminal note" label="note" variant="accent" animation="float" />
  </div>
  <div class="mt-4 grid gap-4 font-mono text-sm">
    {
      terminalCommands.map((item) => (
        <div>
          <p><span class="terminal-prompt text-[#2d9c8c]">$</span> {item.command}<span class="terminal-cursor">_</span></p>
          <p class="mt-1 text-white/68">{item.output}</p>
        </div>
      ))
    }
  </div>
</section>

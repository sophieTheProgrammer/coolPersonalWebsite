---
import { editMap, siteInfo } from "../data/site";
---

<footer class="mt-20 border-t border-[var(--color-line)] bg-[rgba(255,255,255,0.44)] px-6 py-10 sm:px-10">
  <div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-[1fr_1.2fr]">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.2em] text-[var(--color-muted)]">
        {siteInfo.status}
      </p>
      <h2 class="mt-3 text-2xl font-black">{siteInfo.name}</h2>
      <p class="mt-3 max-w-md leading-7 text-[var(--color-muted)]">{siteInfo.description}</p>
    </div>

    <div>
      <p class="text-sm font-black">Edit map</p>
      <div class="mt-3 grid gap-2 sm:grid-cols-2">
        {
          editMap.map((item) => (
            <div class="rounded-md border border-[var(--color-line)] bg-[var(--color-card)] p-3">
              <p class="text-sm font-bold">{item.label}</p>
              <p class="mt-1 font-mono text-xs text-[var(--color-muted)]">{item.path}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</footer>

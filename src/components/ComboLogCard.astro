---
import DoodleImage from "./DoodleImage.astro";
import LatestBadge from "./LatestBadge.astro";
import VideoEmbed from "./VideoEmbed.astro";
import type { ComboLog, SkillToy } from "../data/skillToys";
import { doodleStickers } from "../data/site";

type Props = {
  combo: ComboLog;
  toy: SkillToy;
};

const { combo, toy } = Astro.props;
const isLatestCombo = combo.id === toy.latestComboId;

const formattedDate = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(new Date(`${combo.date}T00:00:00`));

---

<details
  id={combo.id}
  class="group min-w-[13.5rem] overflow-hidden rounded-lg border border-[var(--color-line)] bg-[var(--color-card)] shadow-sm transition hover:border-[var(--color-accent)] hover:shadow-lg md:min-w-0"
>
  <summary class="cursor-pointer list-none space-y-3 p-3 marker:hidden">
    <div class="flex items-start justify-between gap-3">
      <div>
        <div class="flex items-center gap-2">
          <DoodleImage src={toy.doodleIcon} alt={`${toy.name} hand-drawn icon`} label={toy.name.slice(0, 2)} variant="icon" animation="bob" />
          <p class="text-xs font-black uppercase tracking-[0.18em] text-[var(--color-accent)]">
            {toy.name}
          </p>
        </div>
        <h3 class="mt-1 text-base font-black leading-tight">{combo.title}</h3>
      </div>
      <div class="flex shrink-0 flex-col items-end gap-1">
        {
          isLatestCombo && (
            <LatestBadge />
          )
        }
        <DoodleImage src={doodleStickers[combo.tag]} alt={`${combo.tag} hand-drawn sticker`} label={combo.tag} variant="sticker" animation="none">
          <span slot="fallback" class="rounded border border-[var(--color-line)] px-2 py-1 text-xs font-bold text-[var(--color-muted)]">
            {combo.tag}
          </span>
        </DoodleImage>
      </div>
    </div>
    <p class="text-xs font-semibold text-[var(--color-muted)]">{formattedDate}</p>
    <div class="flex items-center justify-between gap-3 text-xs font-bold text-[var(--color-muted)]">
      <span>{combo.notes}</span>
      <span class="shrink-0 text-[var(--color-ink)] group-open:hidden">Open</span>
      <span class="hidden shrink-0 text-[var(--color-ink)] group-open:inline">Close</span>
    </div>
  </summary>
  <div class="border-t border-[var(--color-line)] p-3 pt-0">
    <div class="pt-3">
      <VideoEmbed title={combo.title} embedUrl={combo.embedUrl} />
    </div>
  </div>
</details>

---
import type { CodingProject } from "../data/codingProjects";

type Props = {
  project: CodingProject;
};

const { project } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const statusAccent: Record<CodingProject["status"], string> = {
  building: "gold",
  shipped: "teal",
  experiment: "violet",
  paused: "rose",
  learning: "violet",
  complete: "teal",
};
const accent = statusAccent[project.status];

const getHref = (href: string) =>
  href.startsWith("http") || href.startsWith("#") || href.startsWith("/")
    ? href
    : `${base}${href}`;
---

<article
  class:list={[
    "coding-project-card site-card site-card--interactive grid gap-5 rounded-lg p-4 transition hover:-translate-y-0.5 hover:shadow-lg md:grid-cols-[1fr_14rem]",
    `coding-project-card--${accent}`,
    project.spotlight ? "coding-project-card--spotlight" : "",
  ]}
>
  <div class="space-y-4">
    <div class="flex flex-wrap items-center gap-3">
      <span class="rounded bg-[var(--color-ink)] px-2.5 py-1 text-xs font-black uppercase tracking-[0.14em] text-white">
        {project.status}
      </span>
      {
        project.spotlight && (
          <span class="coding-project-card__spotlight-label rounded px-2.5 py-1 text-xs font-black uppercase tracking-[0.14em]">
            Big build
          </span>
        )
      }
      <h2 class="text-2xl font-black">{project.title}</h2>
    </div>
    <p class="max-w-3xl leading-7 text-[var(--color-muted)]">{project.summary}</p>
    <div class="flex flex-wrap gap-2">
      {
        project.stack.map((item) => (
          <span class="site-chip px-2.5 py-1">
            {item}
          </span>
        ))
      }
    </div>
  </div>

  <div class="flex flex-col justify-center rounded-md border border-[var(--color-line)] p-3">
    <div class="grid gap-2">
      {
        project.links.length > 0 ? (
          project.links.map((link) => (
            <a
              class="site-button rounded-md px-3 py-2 text-center text-sm"
              href={getHref(link.href)}
            >
              {link.label}
            </a>
          ))
        ) : (
          <span class="rounded-md border border-dashed border-[var(--color-line)] px-3 py-2 text-center text-sm font-bold text-[var(--color-muted)]">
            Link later
          </span>
        )
      }
    </div>
  </div>
</article>

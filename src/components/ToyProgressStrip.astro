---
import DoodleImage from "./DoodleImage.astro";
import type { SkillToy } from "../data/skillToys";

type Props = {
  toys: SkillToy[];
};

const { toys } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const loopedToys = [...toys, ...toys];
---

<div class="toy-orbit-rail" aria-label="Open toy trick logs" data-toy-orbit-rail>
  <div class="toy-orbit-rail__track">
    {
      loopedToys.map((toy, index) => {
        const tilt = `${(index - 2) * 0.35}deg`;

        return (
          <a
            class="toy-orbit-rail__node orbit-node"
            href={`${base}skill-toys/${toy.slug}/`}
            style={`--toy-progress: ${toy.progressScore}%; --toy-tilt: ${tilt};`}
            aria-hidden={index >= toys.length ? "true" : undefined}
            tabindex={index >= toys.length ? "-1" : undefined}
          >
            <div class="toy-orbit-rail__meter">
              <span></span>
            </div>
            <div class="toy-orbit-rail__content">
              <DoodleImage src={toy.doodleIcon} alt={`${toy.name} hand-drawn icon`} label={toy.name.slice(0, 2)} variant="icon" animation="none" />
              <h3>{toy.name}</h3>
              <p>{toy.status} / {toy.clipCount} clips</p>
            </div>
            <strong>{toy.progressScore}%</strong>
          </a>
        );
      })
    }
  </div>
</div>

<script>
  const windowWithToyOrbit = window as Window & {
    __toyOrbitInit?: () => void;
  };

  if (windowWithToyOrbit.__toyOrbitInit) {
    document.removeEventListener("astro:page-load", windowWithToyOrbit.__toyOrbitInit);
  }

  windowWithToyOrbit.__toyOrbitInit = () => {
    document.querySelectorAll<HTMLElement>("[data-toy-orbit-rail]").forEach((rail) => {
      if (rail.dataset.orbitReady === "true") {
        return;
      }

      rail.dataset.orbitReady = "true";
      let pauseTimer: number | undefined;

      const pauseForInteraction = () => {
        rail.classList.add("toy-orbit-rail--paused");
        window.clearTimeout(pauseTimer);
        pauseTimer = window.setTimeout(() => {
          rail.classList.remove("toy-orbit-rail--paused");
        }, 1400);
      };

      ["pointerdown", "touchstart", "wheel", "scroll", "keydown"].forEach((eventName) => {
        rail.addEventListener(eventName, pauseForInteraction, { passive: true });
      });
    });
  };

  document.addEventListener("astro:page-load", windowWithToyOrbit.__toyOrbitInit);
  windowWithToyOrbit.__toyOrbitInit();
</script>

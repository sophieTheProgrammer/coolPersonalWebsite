---
type Props = {
  title: string;
  embedUrl?: string;
  videoUrl?: string;
};

const { title, embedUrl, videoUrl } = Astro.props;
---

<div class="overflow-hidden rounded-md border border-[var(--color-line)] bg-[var(--color-ink)] shadow-sm">
  {
    embedUrl ? (
      <iframe
        class="aspect-video w-full"
        src={embedUrl}
        title={title}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      />
    ) : (
      <div class="flex aspect-video w-full flex-col items-center justify-center gap-3 p-6 text-center text-white">
        <div class="grid h-14 w-14 place-items-center rounded-full border border-white/30 bg-white/10 text-lg font-black">
          Play
        </div>
        <div>
          <p class="font-bold">{title}</p>
          <p class="mt-1 text-sm text-white/68">
            Add a YouTube or Vimeo embed URL to make this card playable.
          </p>
        </div>
        {
          videoUrl && (
            <a class="text-sm font-semibold underline underline-offset-4" href={videoUrl}>
              Open video
            </a>
          )
        }
      </div>
    )
  }
</div>

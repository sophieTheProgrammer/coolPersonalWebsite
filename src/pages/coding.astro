---
import CodingProjectCard from "../components/CodingProjectCard.astro";
import TerminalPanel from "../components/TerminalPanel.astro";
import { codingProjects } from "../data/codingProjects";
import BaseLayout from "../layouts/BaseLayout.astro";

const projectData = JSON.stringify(codingProjects);
---

<BaseLayout
  title="Coding | Cool Personal Website"
  description="Coding projects, current builds, and GAME JAMS!!."
>
  <main class="min-h-screen px-6 py-12 sm:px-10">
    <section class="mx-auto max-w-6xl">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(26rem,1.05fr)] lg:items-start">
        <div>
          <h1 class="max-w-4xl text-4xl font-black leading-none sm:text-6xl">
            Projects
          </h1>
        </div>
        <TerminalPanel />
      </div>

      <section class="mt-8 grid gap-4 rounded-lg border border-[var(--color-line)] bg-[var(--color-card)] p-4 shadow-sm lg:grid-cols-[0.9fr_1.1fr]" data-project-console>
        <div>
          <h2 class="text-3xl leading-none" data-console-title>
            Select a project
          </h2>
          <p class="mt-3 leading-7 text-[var(--color-muted)]" data-console-summary>
            Click Load console on any project to inspect its status, stack, links, notes, and next action.
          </p>
        </div>
        <div class="grid gap-3">
          <div class="flex flex-wrap gap-2" data-console-stack></div>
          <div class="rounded-md border border-[var(--color-line)] bg-white/50 p-3">
            <p class="text-xs font-black uppercase tracking-[0.16em] text-[var(--color-muted)]">Status</p>
            <p class="mt-1 font-black" data-console-status>Waiting</p>
          </div>
          <div class="rounded-md border border-[var(--color-line)] bg-white/50 p-3">
            <p class="text-xs font-black uppercase tracking-[0.16em] text-[var(--color-muted)]">Notes</p>
            <p class="mt-1 leading-7 text-[var(--color-muted)]" data-console-notes>Pick a project to load notes.</p>
          </div>
          <div class="rounded-md border border-[var(--color-line)] bg-[var(--color-ink)] p-3 text-white">
            <p class="text-xs font-black uppercase tracking-[0.16em] text-white/55">Next command</p>
            <p class="mt-1 font-mono text-sm" data-console-action>$ select-project</p>
          </div>
          <div class="flex flex-wrap gap-2" data-console-links></div>
        </div>
      </section>

      <section class="mt-12" aria-labelledby="projects-heading">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <h2 id="projects-heading" class="text-3xl font-black">
              Build log
            </h2>
          </div>
          <p class="text-sm font-semibold text-[var(--color-muted)]">
            {codingProjects.length} entries
          </p>
        </div>

        <div class="mt-5 grid gap-4">
          {codingProjects.map((project) => <CodingProjectCard project={project} />)}
        </div>
      </section>

    </section>
  </main>
</BaseLayout>

<script type="application/json" id="coding-project-data" is:inline set:html={projectData} />

<script>
  type CodingProject = {
    title: string;
    slug: string;
    status: string;
    summary: string;
    stack: string[];
    notes?: string;
    nextAction?: string;
    links: { label: string; href: string }[];
  };

  const dataElement = document.querySelector("#coding-project-data");
  const projects: CodingProject[] = dataElement?.textContent
    ? JSON.parse(dataElement.textContent)
    : [];

  const title = document.querySelector("[data-console-title]");
  const summary = document.querySelector("[data-console-summary]");
  const status = document.querySelector("[data-console-status]");
  const notes = document.querySelector("[data-console-notes]");
  const action = document.querySelector("[data-console-action]");
  const stack = document.querySelector("[data-console-stack]");
  const links = document.querySelector("[data-console-links]");
  const terminal = document.querySelector("[data-terminal-active]");

  const loadProject = (slug: string) => {
    const project = projects.find((item) => item.slug === slug);
    if (!project) return;

    document.querySelectorAll("[data-project-card]").forEach((card) => {
      card.toggleAttribute("data-project-active", card.getAttribute("data-project-card") === slug);
    });

    if (title) title.textContent = project.title;
    if (summary) summary.textContent = project.summary;
    if (status) status.textContent = project.status;
    if (notes) notes.textContent = project.notes ?? "No notes yet.";
    if (action) action.textContent = `$ ${project.nextAction ?? "Write the next action"}`;

    if (stack) {
      stack.innerHTML = project.stack
        .map((item) => `<span class="site-chip px-2.5 py-1">${item}</span>`)
        .join("");
    }

    if (links) {
      links.innerHTML = project.links
        .filter((link) => link.href)
        .map((link) => `<a class="site-button rounded-md px-3 py-2 text-sm" href="${link.href}">${link.label}</a>`)
        .join("");
    }

    if (terminal) {
      terminal.innerHTML = `<p><span class="terminal-prompt text-[#2d9c8c]">$</span> ${project.slug}<span class="terminal-cursor">_</span></p><p class="mt-1 text-white/68">${project.nextAction ?? project.summary}</p>`;
    }
  };

  document.querySelectorAll("[data-project-select]").forEach((button) => {
    button.addEventListener("click", () => {
      const slug = button.getAttribute("data-project-select");
      if (slug) loadProject(slug);
    });
  });

  if (projects[0]) {
    loadProject(projects[0].slug);
  }
</script>

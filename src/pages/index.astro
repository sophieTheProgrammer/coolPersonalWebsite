---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomePersonFigure from "../components/HomePersonFigure.astro";
import { homeContent } from "../data/site";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Cool Personal Website">
  <main class="min-h-screen overflow-hidden px-6 py-12 sm:px-10">
    <section class="mx-auto grid min-h-[78vh] max-w-6xl items-center gap-12 lg:grid-cols-[1.25fr_0.75fr]">
      <div class="relative">
        <div
          class="home-orbit absolute -left-8 top-2 h-24 w-24 rounded-full border border-[var(--color-line)] bg-[rgba(228,87,122,0.16)]"
        >
        </div>
        <div
          class="home-orbit-delayed absolute right-10 top-24 h-28 w-28 rounded-md border border-[var(--color-line)] bg-[rgba(45,156,140,0.16)]"
        >
        </div>
        <div class="hero-with-person">
          <h1 class="max-w-3xl text-5xl font-black leading-[0.95] sm:text-7xl">
            {homeContent.headline}
          </h1>
          <HomePersonFigure src={homeContent.studioAvatarDoodle} />
        </div>

        <div class="home-social-links mt-6 flex flex-wrap gap-3">
          {
            homeContent.socialLinks.map((link) => (
              <a
                class:list={[
                  "home-social-card group rounded-md border border-[var(--color-line)] bg-[var(--color-card)] px-4 py-3 shadow-sm transition hover:-translate-y-0.5 hover:border-[var(--color-accent)]",
                  link.kind === "youtube" ? "home-social-card--youtube" : "home-social-card--github",
                ]}
                href={link.href}
                target="_blank"
                rel="noreferrer"
              >
                <span class="home-social-card__icon" aria-hidden="true">
                  <span></span>
                </span>
                <span class="block font-black">{link.label}</span>
              </a>
            ))
          }
        </div>
      </div>

      <div class="relative rounded-lg border border-[var(--color-line)] bg-white p-5 shadow-sm">
        <div class="grid gap-3">
          {
            homeContent.sections.map((section, index) => (
              <a
                class:list={[
                  "home-section-card rounded-md border border-[var(--color-line)] p-5 transition hover:border-[var(--color-accent)]",
                  index === 0 && "home-section-card--wide",
                  index === 1 && "home-section-card--tilt-left",
                  index === 2 && "home-section-card--tilt-right",
                ]}
                href={`${base}${section.href}`}
              >
                <span class:list={["block font-black", section.featured ? "text-2xl" : "text-xl"]}>
                  {section.title}
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

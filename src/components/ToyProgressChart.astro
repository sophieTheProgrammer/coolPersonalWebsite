---
import type { SkillToy } from "../data/skillToys";

type Props = {
  toys: SkillToy[];
};

const { toys } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<div class="rounded-lg border border-[var(--color-line)] bg-[var(--color-card)] p-4 shadow-sm">
  <div class="flex items-center justify-between gap-4">
    <div>
      <h2 id="overview-heading" class="text-lg font-black">Toy progress</h2>
      <p class="mt-1 text-sm text-[var(--color-muted)]">Click a toy below to see its trick log.</p>
    </div>
    <p class="text-xs font-semibold text-[var(--color-muted)]">{toys.length} toys tracked</p>
  </div>
  <div class="mt-4 h-72">
    <canvas
      data-toy-progress-chart
      data-base-url={base}
      data-toys={JSON.stringify(toys)}
      aria-label="Skill toy progress bar chart"
    >
    </canvas>
  </div>
</div>

<script>
  import {
    BarController,
    BarElement,
    CategoryScale,
    Chart,
    LinearScale,
    Tooltip,
  } from "chart.js";

  Chart.register(BarController, BarElement, CategoryScale, LinearScale, Tooltip);

  const windowWithToyCharts = window as Window & {
    __toyProgressChartInit?: () => void;
    __toyProgressCharts?: WeakMap<HTMLCanvasElement, Chart>;
  };

  if (windowWithToyCharts.__toyProgressChartInit) {
    document.removeEventListener(
      "astro:page-load",
      windowWithToyCharts.__toyProgressChartInit,
    );
  }

  windowWithToyCharts.__toyProgressCharts ??= new WeakMap<
    HTMLCanvasElement,
    Chart
  >();

  windowWithToyCharts.__toyProgressChartInit = () => {
    const canvases = document.querySelectorAll("[data-toy-progress-chart]");

    canvases.forEach((canvas) => {
      if (!(canvas instanceof HTMLCanvasElement)) return;

      const existingChart = windowWithToyCharts.__toyProgressCharts?.get(canvas);
      existingChart?.destroy();

      const toys = JSON.parse(canvas.dataset.toys ?? "[]") as Array<{
        name: string;
        slug: string;
        progressScore: number;
        status: string;
      }>;
      const baseUrl = canvas.dataset.baseUrl ?? "/";
      const styles = getComputedStyle(document.documentElement);
      const accent = styles.getPropertyValue("--color-accent").trim();
      const accentTwo = styles.getPropertyValue("--color-accent-2").trim();
      const muted = styles.getPropertyValue("--color-muted").trim();

      const chart = new Chart(canvas, {
        type: "bar",
        data: {
          labels: toys.map((toy) => toy.name),
          datasets: [
            {
              label: "Progress",
              data: toys.map((toy) => toy.progressScore),
              backgroundColor: toys.map((toy) =>
                toy.status === "active" ? accent : accentTwo,
              ),
              borderColor: "rgba(30, 27, 46, 0.16)",
              borderWidth: 1,
              borderRadius: 10,
              barThickness: 34,
              maxBarThickness: 44,
              hoverBackgroundColor: accent,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          animation: { duration: 220 },
          layout: {
            padding: {
              top: 8,
            },
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              displayColors: false,
              callbacks: {
                label: (context) => {
                  const toy = toys[context.dataIndex];
                  return `${context.parsed.y}% progress / ${toy.status}`;
                },
              },
            },
          },
          scales: {
            x: {
              grid: { display: false },
              ticks: { color: muted, font: { weight: "bold" } },
            },
            y: {
              beginAtZero: true,
              max: 100,
              grid: { color: "rgba(30, 27, 46, 0.08)" },
              ticks: {
                color: muted,
                callback: (value) => `${value}%`,
              },
            },
          },
          onClick: (_event, elements) => {
            const first = elements[0];
            if (!first) return;
            const toy = toys[first.index];
            if (toy) {
              window.location.href = `${baseUrl}skill-toys/${toy.slug}/`;
            }
          },
          onHover: (event, elements) => {
            if (event.native?.target instanceof HTMLElement) {
              event.native.target.style.cursor = elements.length
                ? "pointer"
                : "default";
            }
          },
        },
      });

      windowWithToyCharts.__toyProgressCharts?.set(canvas, chart);
    });
  };

  document.addEventListener(
    "astro:page-load",
    windowWithToyCharts.__toyProgressChartInit,
  );
  windowWithToyCharts.__toyProgressChartInit();
</script>
